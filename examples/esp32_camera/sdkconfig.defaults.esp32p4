# ESP32-P4 specific configuration
#
# Chip revision: P4 Nano board is rev v1.0 (v5.5 defaults to v3.1+)
CONFIG_ESP32P4_SELECTS_REV_LESS_V3=y
CONFIG_ESP32P4_REV_MIN_100=y

# Flash
CONFIG_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y

# SPIRAM (required for camera frame buffers and H264 encoder)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_SPEED_200M=y
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
CONFIG_MBEDTLS_EXTERNAL_MEM_ALLOC=y

# Network: Ethernet (ESP32-P4 has internal EMAC, no WiFi)
CONFIG_EXAMPLE_CONNECT_ETHERNET=y
CONFIG_EXAMPLE_CONNECT_WIFI=n
CONFIG_EXAMPLE_USE_INTERNAL_ETHERNET=y
CONFIG_EXAMPLE_ETH_PHY_IP101=y
CONFIG_EXAMPLE_ETH_MDC_GPIO=31
CONFIG_EXAMPLE_ETH_MDIO_GPIO=52
CONFIG_EXAMPLE_ETH_PHY_RST_GPIO=-1
CONFIG_EXAMPLE_ETH_PHY_ADDR=1

#
# ESP32 Camera Example
#
CONFIG_EXAMPLE_VIDEO_WIDTH=1920
CONFIG_EXAMPLE_VIDEO_HEIGHT=1080
CONFIG_EXAMPLE_VIDEO_FPS=30
CONFIG_EXAMPLE_H264_BITRATE_KBPS=1024
CONFIG_EXAMPLE_H264_GOP=60
CONFIG_EXAMPLE_CAM_XCLK_PIN=33
CONFIG_EXAMPLE_CAM_RESET_PIN=-1
CONFIG_EXAMPLE_CAM_PWDN_PIN=-1
CONFIG_EXAMPLE_CAM_SCCB_SCL_PIN=8
CONFIG_EXAMPLE_CAM_SCCB_SDA_PIN=7

# Camera: OV5647 via MIPI CSI (1920x1080 RAW10, max resolution)
CONFIG_CAMERA_OV5647=y
CONFIG_CAMERA_OV5647_MIPI_RAW8_800X800_50FPS=y
CONFIG_CAMERA_OV5647_MIPI_RAW10_1920X1080_30FPS=y
CONFIG_CAMERA_OV5647_MIPI_DEFAULT_FMT_RAW10_1920X1080_30FPS=y
CONFIG_CAMERA_OV5647_MIPI_IF_FORMAT_INDEX_DEFAULT=3
CONFIG_CAMERA_OV5647_CSI_LINESYNC_ENABLE=y
CONFIG_CAMERA_OV5647_DEFAULT_IPA_JSON_CONFIGURATION_FILE=y

# esp_video: only CSI camera device, no JPEG/H264 codec devices
CONFIG_ESP_VIDEO_ENABLE_HW_JPEG_VIDEO_DEVICE=n
CONFIG_ESP_VIDEO_ENABLE_HW_H264_VIDEO_DEVICE=n

# Required for CSI/ISP drivers on ESP32-P4
CONFIG_IDF_EXPERIMENTAL_FEATURES=y
